{
  "name": "mefai-browser",
  "version": "1.3.0",
  "description": "Mefai Trading Browser - AI-Native Trading Browser",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "io.mefai.browser",
    "productName": "Mefai Browser",
    "directories": { "output": "dist" },
    "win": { "target": ["nsis"], "icon": "assets/icon.png" },
    "mac": { "target": ["dmg"], "icon": "assets/icon.png" },
    "linux": { "target": ["AppImage"], "icon": "assets/icon.png" },
    "publish": {
      "provider": "github",
      "owner": "mefai-dev",
      "repo": "mefai-browser"
    }
  },
  "author": "Mefai <dev@mefai.io>",
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
